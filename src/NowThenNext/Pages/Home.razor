@page "/"

<PageTitle>Home</PageTitle>

<div class="max-w-4xl mx-auto p-6">
    <h1 class="text-4xl font-bold text-gray-800 mb-4">Hello, world!</h1>
    
    <div class="bg-white rounded-lg p-6 shadow-lg border border-gray-200">
        <p class="text-lg text-gray-700 mb-6">Welcome to your new app with Tailwind CSS!</p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-blue-600 text-white p-6 rounded-lg shadow-md">
                <h3 class="text-xl font-semibold mb-3">Feature 1</h3>
                <p class="text-blue-100">This card demonstrates Tailwind's utility classes with improved contrast</p>
            </div>
            
            <div class="bg-green-600 text-white p-6 rounded-lg shadow-md">
                <h3 class="text-xl font-semibold mb-3">Feature 2</h3>
                <p class="text-green-100">Responsive design with Tailwind is easy and accessible!</p>
            </div>
        </div>
        
        <div class="mt-8 flex flex-wrap gap-4">
            <button class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors duration-200 shadow-md">
                Primary Action
            </button>
            <button class="bg-gray-600 hover:bg-gray-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors duration-200 shadow-md">
                Secondary Action
            </button>
        </div>
    </div>
</div>
